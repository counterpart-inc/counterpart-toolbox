#!/usr/bin/env bash
# yourcounterpart — Counterpart AI toolbox installer + syncer
# Usage:
#   yourcounterpart          → health check, show environment status
#   yourcounterpart setup    → detect agents, install company context
#   yourcounterpart sync     → push .counterpart/ content to all providers
#   yourcounterpart update   → pull latest toolbox, update .counterpart/, re-sync
#   yourcounterpart status   → show health check results
#   yourcounterpart reset    → clear configuration and start fresh
#   yourcounterpart uninstall → remove yourcounterpart from this machine

set -euo pipefail

# ── Resolve toolbox root ────────────────────────────────────────────────────────
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  if [[ "$SOURCE" != /* ]]; then SOURCE="$DIR/$SOURCE"; fi
done
export TOOLBOX_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

# ── Load lib scripts ────────────────────────────────────────────────────────────
# shellcheck source=lib/check_tools.sh
source "${TOOLBOX_DIR}/lib/check_tools.sh"
# shellcheck source=lib/check_mcp.sh
source "${TOOLBOX_DIR}/lib/check_mcp.sh"
# shellcheck source=lib/context-lock.sh
source "${TOOLBOX_DIR}/lib/context-lock.sh"
# shellcheck source=lib/sync.sh
source "${TOOLBOX_DIR}/lib/sync.sh"

# ── Constants ───────────────────────────────────────────────────────────────────
TOOLBOX_INSTALL_DIR="${HOME}/.local/share/counterpart-toolbox"
TOOLBOX_VERSION="$(cat "${TOOLBOX_DIR}/VERSION" 2>/dev/null | tr -d '[:space:]' || echo "unknown")"
WORKSPACE_FILE="${HOME}/.config/counterpart/workspace"

# ── Colour helpers ──────────────────────────────────────────────────────────────
BOLD="\033[1m"
RESET="\033[0m"
CYAN="\033[36m"
YELLOW="\033[33m"

banner() {
  echo ""
  echo -e "${BOLD}${CYAN}  yourcounterpart — Counterpart AI toolbox${RESET}  ${YELLOW}v${TOOLBOX_VERSION}${RESET}"
  echo -e "  ${YELLOW}yourcounterpart.com${RESET}"
  echo ""
}

# ── Update check ─────────────────────────────────────────────────────────────────

check_for_update() {
  if [[ ! -d "${TOOLBOX_INSTALL_DIR}/.git" ]]; then return 0; fi
  local remote_version
  remote_version=$(git -C "$TOOLBOX_INSTALL_DIR" show origin/main:VERSION 2>/dev/null | tr -d '[:space:]' || echo "")
  if [[ -n "$remote_version" && "$remote_version" != "$TOOLBOX_VERSION" ]]; then
    echo -e "  ${YELLOW}↑${RESET} Update available: ${TOOLBOX_VERSION} → ${remote_version}  (run: ${BOLD}yourcounterpart update${RESET})"
    echo ""
  fi
}

trigger_background_fetch() {
  if [[ ! -d "${TOOLBOX_INSTALL_DIR}/.git" ]]; then return 0; fi
  git -C "$TOOLBOX_INSTALL_DIR" fetch origin main --quiet 2>/dev/null &
}

# ── Workspace resolution ────────────────────────────────────────────────────────

load_workspace() {
  local ws="${COUNTERPART_WORKSPACE:-}"
  if [[ -z "$ws" && -f "$WORKSPACE_FILE" ]]; then
    ws=$(cat "$WORKSPACE_FILE" 2>/dev/null | tr -d '[:space:]')
  fi
  ws="${ws%/}"
  if [[ "${ws##*/}" == ".counterpart" ]]; then
    ws="$(dirname "$ws")"
  fi
  if [[ -z "$ws" || ! -d "$ws" || ! -d "${ws}/.counterpart" ]]; then
    return 1
  fi
  export COUNTERPART_WORKSPACE="$ws"
  export COUNTERPART_CONFIG="${ws}/.counterpart/config.json"
  return 0
}

_inject_workspace_env() {
  local workspace="$1"
  mkdir -p "$(dirname "$WORKSPACE_FILE")"
  echo "$workspace" > "$WORKSPACE_FILE"
  local export_line="export COUNTERPART_WORKSPACE=\"${workspace}\""
  for rc_file in "${HOME}/.zshrc" "${HOME}/.bashrc"; do
    if [[ ! -f "$rc_file" ]]; then continue; fi
    if grep -qF "COUNTERPART_WORKSPACE" "$rc_file"; then
      local tmp; tmp=$(mktemp)
      grep -v "COUNTERPART_WORKSPACE" "$rc_file" > "$tmp"
      printf '\n%s\n' "$export_line" >> "$tmp"
      mv "$tmp" "$rc_file"
    else
      printf '\n%s\n' "$export_line" >> "$rc_file"
    fi
    echo "  [✓] Set COUNTERPART_WORKSPACE in ${rc_file}"
  done
  export COUNTERPART_WORKSPACE="$workspace"
}

# ── Boilerplate copy ────────────────────────────────────────────────────────────

_copy_boilerplate() {
  local cp_dir="$1"
  local bp_dir="${TOOLBOX_DIR}"
  if [[ ! -d "$bp_dir" ]]; then return 0; fi

  for type in agents rules; do
    if [[ -d "${bp_dir}/${type}" ]] && [[ -z "$(ls -A "${cp_dir}/${type}" 2>/dev/null)" ]]; then
      cp -r "${bp_dir}/${type}/." "${cp_dir}/${type}/"
    fi
  done

  if [[ -d "${bp_dir}/skills" ]]; then
    for skill_dir in "${bp_dir}/skills"/*/; do
      [[ -d "$skill_dir" ]] || continue
      local sname; sname=$(basename "$skill_dir")
      if [[ ! -d "${cp_dir}/skills/${sname}" ]]; then
        cp -r "$skill_dir" "${cp_dir}/skills/${sname}"
      fi
    done
  fi
}

# ── Internal sync ───────────────────────────────────────────────────────────────

_do_sync() {
  local cp_dir="$1"
  sync_global "$cp_dir"
  write_agents_lock "$cp_dir" "$TOOLBOX_DIR" "${COUNTERPART_WORKSPACE}"
  if [[ -f "$COUNTERPART_CONFIG" ]] && command -v jq &>/dev/null; then
    local tmp; tmp=$(mktemp)
    jq --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" '.last_sync = $ts' "$COUNTERPART_CONFIG" > "$tmp" && mv "$tmp" "$COUNTERPART_CONFIG"
  fi
}

# ── Setup flow ──────────────────────────────────────────────────────────────────

run_setup() {
  banner
  echo -e "${BOLD}First-time setup${RESET}"
  echo ""

  # 1. Workspace path
  local default_workspace="${PWD}"
  printf "  Workspace folder [%s]: " "$default_workspace"
  read -r workspace </dev/tty
  workspace="${workspace:-$default_workspace}"
  workspace="${workspace/#\~/$HOME}"
  workspace="${workspace%/}"
  if [[ "${workspace##*/}" == ".counterpart" ]]; then
    workspace="$(dirname "$workspace")"
  fi

  if [[ ! -d "$workspace" ]]; then
    printf "  '%s' does not exist. Create it? [Y/n] " "$workspace"
    read -r answer </dev/tty
    [[ "${answer:-Y}" =~ ^[Yy]$ ]] || { echo "  Aborted."; exit 1; }
    mkdir -p "$workspace"
  fi

  # 2. Create .counterpart/ structure
  local cp_dir="${workspace}/.counterpart"
  mkdir -p "${cp_dir}/agents" "${cp_dir}/skills" "${cp_dir}/rules"

  # 3. Copy boilerplate
  _copy_boilerplate "$cp_dir"
  echo "  [✓] Created ${cp_dir}/"
  echo ""

  # 4. Inject COUNTERPART_WORKSPACE into shell rc
  _inject_workspace_env "$workspace"
  export COUNTERPART_CONFIG="${cp_dir}/config.json"
  echo ""

  # 5. Detect providers
  echo -e "${BOLD}Detecting AI agents...${RESET}"
  echo ""
  local detected_providers=()
  if command -v claude &>/dev/null;   then detected_providers+=("claude");   echo "  [✓] Claude Code"; fi
  if [[ -d "${HOME}/.cursor" ]];      then detected_providers+=("cursor");   echo "  [✓] Cursor"; fi
  if command -v opencode &>/dev/null; then detected_providers+=("opencode"); echo "  [✓] OpenCode"; fi
  if [[ -d "${HOME}/.config/github-copilot" ]]; then detected_providers+=("copilot"); echo "  [✓] Copilot"; fi
  if [[ -d "${HOME}/.gemini" ]];      then detected_providers+=("gemini");   echo "  [✓] Gemini"; fi
  if [[ -d "${HOME}/.pi" ]];          then detected_providers+=("pi");       echo "  [✓] Pi"; fi
  echo ""

  # 6. Write config.json
  local providers_json
  providers_json=$(printf '%s\n' "${detected_providers[@]}" | jq -Rsc 'split("\n") | map(select(length>0))' 2>/dev/null || echo "[]")
  jq -n \
    --arg workspace "$workspace" \
    --argjson providers "$providers_json" \
    '{
      workspace: $workspace,
      providers: $providers,
      last_sync: "",
      required_tools: [
        {"cmd": "jq",       "brew": "jq"},
        {"cmd": "rg",       "brew": "ripgrep"},
        {"cmd": "ast-grep", "brew": "ast-grep"}
      ],
      mcp_servers: {
        linear:   "https://mcp.linear.app/sse",
        sentry:   "https://mcp.sentry.dev/mcp",
        context7: "https://mcp.context7.com/mcp"
      }
    }' > "$COUNTERPART_CONFIG"
  echo "  [✓] Config: $COUNTERPART_CONFIG"
  echo ""

  # 7. Health checks
  echo -e "${BOLD}Health checks...${RESET}"
  echo ""
  check_tools
  echo ""
  check_mcp_servers
  echo ""

  # 8. Sync to providers
  echo -e "${BOLD}Syncing to agents...${RESET}"
  echo ""
  _do_sync "$cp_dir"
  echo ""

  echo -e "${BOLD}Setup complete.${RESET} Open your AI agent — company context is already configured."
  echo ""
}

# ── Sync flow ───────────────────────────────────────────────────────────────────

run_sync() {
  banner
  if ! load_workspace; then
    echo "  [!] COUNTERPART_WORKSPACE not set. Run: yourcounterpart setup"
    echo ""
    exit 1
  fi

  echo -e "${BOLD}Syncing to agents...${RESET}"
  echo ""
  _do_sync "${COUNTERPART_WORKSPACE}/.counterpart"
  echo ""
  echo -e "${BOLD}Sync complete.${RESET}"
  echo ""
}

# ── Update flow ─────────────────────────────────────────────────────────────────

run_update() {
  banner
  if ! load_workspace; then
    echo "  [!] COUNTERPART_WORKSPACE not set. Run: yourcounterpart setup"
    echo ""
    exit 1
  fi

  echo -e "${BOLD}Updating counterpart-toolbox...${RESET}"
  echo ""

  if [[ -d "${TOOLBOX_INSTALL_DIR}/.git" ]]; then
    local version_before="$TOOLBOX_VERSION"

    echo "  Pulling latest toolbox..."
    git -C "$TOOLBOX_INSTALL_DIR" pull origin main 2>&1 | sed 's/^/  /'
    echo ""

    local version_after
    version_after=$(cat "${TOOLBOX_INSTALL_DIR}/VERSION" 2>/dev/null | tr -d '[:space:]' || echo "unknown")
    if [[ "$version_after" != "$version_before" ]]; then
      echo "  [✓] Toolbox updated: v${version_before} → v${version_after}"
    else
      echo "  [✓] Toolbox already at v${version_after}"
    fi
    echo ""
  fi

  # Update .counterpart/ from toolbox root
  local cp_dir="${COUNTERPART_WORKSPACE}/.counterpart"
  echo "  Updating .counterpart from toolbox..."
  for type in agents rules; do
    if [[ -d "${TOOLBOX_DIR}/${type}" ]]; then
      rsync -a --delete "${TOOLBOX_DIR}/${type}/" "${cp_dir}/${type}/" 2>/dev/null || \
        cp -r "${TOOLBOX_DIR}/${type}/." "${cp_dir}/${type}/"
    fi
  done
  if [[ -d "${TOOLBOX_DIR}/skills" ]]; then
    rsync -a --delete "${TOOLBOX_DIR}/skills/" "${cp_dir}/skills/" 2>/dev/null || \
      cp -r "${TOOLBOX_DIR}/skills/." "${cp_dir}/skills/"
  fi
  echo "  [✓] .counterpart updated"
  echo ""

  echo -e "${BOLD}Syncing to agents...${RESET}"
  echo ""
  _do_sync "$cp_dir"
  echo ""

  echo -e "${BOLD}Update complete.${RESET}"
  echo ""
}

# ── Reset flow ──────────────────────────────────────────────────────────────────

run_reset() {
  banner
  echo -e "${BOLD}Reset yourcounterpart configuration${RESET}"
  echo ""
  echo "  This will delete:"
  if [[ -n "${COUNTERPART_WORKSPACE:-}" ]]; then
    echo "    • ${COUNTERPART_WORKSPACE}/.counterpart/  (workspace config + agents)"
  fi
  echo "    • ${WORKSPACE_FILE}"
  echo "    • COUNTERPART_WORKSPACE from ~/.zshrc / ~/.bashrc"
  echo ""
  printf "  Are you sure? [y/N] "
  read -r answer </dev/tty
  [[ "${answer:-N}" =~ ^[Yy]$ ]] || { echo "  Aborted."; exit 0; }

  if [[ -n "${COUNTERPART_WORKSPACE:-}" && -d "${COUNTERPART_WORKSPACE}/.counterpart" ]]; then
    rm -rf "${COUNTERPART_WORKSPACE}/.counterpart"
    echo "  [✓] Removed ${COUNTERPART_WORKSPACE}/.counterpart/"
  fi

  rm -f "$WORKSPACE_FILE"
  echo "  [✓] Removed ${WORKSPACE_FILE}"

  for rc_file in "${HOME}/.zshrc" "${HOME}/.bashrc"; do
    if [[ -f "$rc_file" ]] && grep -qF "COUNTERPART_WORKSPACE" "$rc_file"; then
      local tmp; tmp=$(mktemp)
      grep -v "COUNTERPART_WORKSPACE" "$rc_file" > "$tmp"
      mv "$tmp" "$rc_file"
      echo "  [✓] Removed COUNTERPART_WORKSPACE from ${rc_file}"
    fi
  done

  echo ""
  echo -e "${BOLD}Reset complete.${RESET} Run 'yourcounterpart setup' to reconfigure."
  echo ""
}

# ── Uninstall flow ───────────────────────────────────────────────────────────────

run_uninstall() {
  banner
  echo -e "${BOLD}Uninstall yourcounterpart${RESET}"
  echo ""
  echo "  This will delete:"
  echo "    • ${HOME}/.local/bin/yourcounterpart  (symlink)"
  echo "    • ${TOOLBOX_INSTALL_DIR}/  (toolbox repo)"
  echo "    • ${WORKSPACE_FILE}"
  echo "    • COUNTERPART_WORKSPACE from shell rc files"
  if [[ -n "${COUNTERPART_WORKSPACE:-}" ]]; then
    echo ""
    printf "  Also remove workspace config (%s/.counterpart/)? [y/N] " "$COUNTERPART_WORKSPACE"
    read -r remove_workspace </dev/tty
    remove_workspace="${remove_workspace:-N}"
  fi

  echo ""
  printf "  Are you sure you want to uninstall? [y/N] "
  read -r answer </dev/tty
  [[ "${answer:-N}" =~ ^[Yy]$ ]] || { echo "  Aborted."; exit 0; }

  rm -f "${HOME}/.local/bin/yourcounterpart"
  echo "  [✓] Removed symlink."

  for rc_file in "${HOME}/.zshrc" "${HOME}/.bashrc" "${HOME}/.bash_profile"; do
    if [[ -f "$rc_file" ]] && grep -qF 'yourcounterpart' "$rc_file"; then
      local tmp; tmp=$(mktemp)
      grep -v 'yourcounterpart' "$rc_file" | grep -v 'counterpart-toolbox installer' | grep -v 'COUNTERPART_WORKSPACE' > "$tmp"
      mv "$tmp" "$rc_file"
      echo "  [✓] Cleaned ${rc_file}"
    fi
  done

  if [[ -d "$TOOLBOX_INSTALL_DIR" ]]; then
    rm -rf "$TOOLBOX_INSTALL_DIR"
    echo "  [✓] Removed ${TOOLBOX_INSTALL_DIR}/"
  fi

  rm -f "$WORKSPACE_FILE"
  rmdir "$(dirname "$WORKSPACE_FILE")" 2>/dev/null || true
  echo "  [✓] Removed ${WORKSPACE_FILE}"

  if [[ "${remove_workspace:-N}" =~ ^[Yy]$ && -n "${COUNTERPART_WORKSPACE:-}" ]]; then
    rm -rf "${COUNTERPART_WORKSPACE}/.counterpart"
    echo "  [✓] Removed ${COUNTERPART_WORKSPACE}/.counterpart/"
  fi

  echo ""
  echo -e "${BOLD}Uninstalled.${RESET} To reinstall, follow the onboarding instructions."
  echo ""
}

# ── Status subcommand ───────────────────────────────────────────────────────────

run_status() {
  banner
  if ! load_workspace; then
    echo "  [!] COUNTERPART_WORKSPACE not set. Run: yourcounterpart setup"
    echo ""
    exit 1
  fi

  check_for_update
  echo "  Version:    v${TOOLBOX_VERSION}"
  echo "  Workspace:  ${COUNTERPART_WORKSPACE}"
  echo ""

  if command -v jq &>/dev/null && [[ -f "$COUNTERPART_CONFIG" ]]; then
    local providers last_sync
    providers=$(jq -r '(.providers // []) | join(", ")' "$COUNTERPART_CONFIG" 2>/dev/null)
    last_sync=$(jq -r '.last_sync // "never"' "$COUNTERPART_CONFIG" 2>/dev/null)
    echo "  Providers:  ${providers:-(none)}"
    echo "  Last sync:  ${last_sync:-never}"
  fi

  local lock_file="${COUNTERPART_WORKSPACE}/.counterpart/toolbox.lock"
  if [[ -f "$lock_file" ]] && command -v jq &>/dev/null; then
    local commit rule_count skill_count
    commit=$(jq -r '.sources | to_entries[0].value.commit // "unknown"' "$lock_file" 2>/dev/null | cut -c1-7)
    rule_count=$(jq -r '.sources | to_entries[0].value.rules | length' "$lock_file" 2>/dev/null || echo "0")
    skill_count=$(jq -r '.sources | to_entries[0].value.skills | length' "$lock_file" 2>/dev/null || echo "0")
    echo "  Plugins @:  ${commit}"
    echo "  Rules:      ${rule_count}"
    echo "  Skills:     ${skill_count}"
  fi

  echo ""
  echo -e "${BOLD}Health checks${RESET}"
  echo ""
  check_tools
  echo ""
  check_mcp_servers
  echo ""

  if [[ -f "${PWD}/context.lock" ]]; then
    if context_lock_validate "context" "context.lock" "$PWD" &>/dev/null; then
      echo "  Context lock: ✓ current"
    else
      echo "  Context lock: ✗ stale — run: yourcounterpart context sync"
    fi
    echo ""
  fi
}

# ── Main entry point ────────────────────────────────────────────────────────────

main() {
  case "${1:-}" in
    setup)
      run_setup
      exit 0
      ;;
    sync)
      run_sync
      exit 0
      ;;
    update)
      run_update
      exit 0
      ;;
    context)
      local subcmd="${2:-}"
      case "$subcmd" in
        sync)
          context_lock_generate "context" "context.lock" "$PWD"
          exit $?
          ;;
        validate)
          context_lock_validate "context" "context.lock" "$PWD"
          exit $?
          ;;
        *)
          echo "  Usage: yourcounterpart context <sync|validate>"
          exit 1
          ;;
      esac
      ;;
    status)
      run_status
      exit 0
      ;;
    reset)
      run_reset
      exit 0
      ;;
    uninstall)
      run_uninstall
      exit 0
      ;;
    --help|-h|help)
      banner
      cat <<'USAGE'
  Usage:
    yourcounterpart            Check environment status
    yourcounterpart setup      One-time setup: workspace, agents, sync
    yourcounterpart sync       Push .counterpart/ content to all providers
    yourcounterpart update     Pull latest toolbox, update .counterpart/, re-sync
    yourcounterpart status     Show health check results
    yourcounterpart context    Manage context.lock for current repo
    yourcounterpart reset      Clear configuration and start fresh
    yourcounterpart uninstall  Remove yourcounterpart from this machine

USAGE
      exit 0
      ;;
  esac

  if ! load_workspace; then
    banner
    echo "  No configuration found. Running first-time setup..."
    echo ""
    run_setup
  else
    echo ""
    echo -e "${BOLD}${CYAN}yourcounterpart${RESET}  v${TOOLBOX_VERSION}  checking environment..."
    echo ""
    check_for_update
    check_tools
    echo ""
    trigger_background_fetch
    echo "  Environment ready. Open your AI agent — company context is already configured."
    echo ""
  fi
}

main "$@"
