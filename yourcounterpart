#!/usr/bin/env bash
# yourcounterpart — Counterpart AI toolbox installer + syncer
# Usage:
#   yourcounterpart          → health check, show environment status
#   yourcounterpart setup    → detect agents, install company context (coming soon)
#   yourcounterpart update   → pull latest plugins, re-sync (coming soon)
#   yourcounterpart status   → show health check results
#   yourcounterpart reset    → clear configuration and start fresh
#   yourcounterpart uninstall → remove yourcounterpart from this machine

set -euo pipefail

# ── Resolve toolbox root ────────────────────────────────────────────────────────
# If invoked via symlink, resolve the real script path so lib/ and templates/ work
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
export TOOLBOX_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

# ── Load lib scripts ────────────────────────────────────────────────────────────
# shellcheck source=lib/check_tools.sh
source "${TOOLBOX_DIR}/lib/check_tools.sh"
# shellcheck source=lib/check_mcp.sh
source "${TOOLBOX_DIR}/lib/check_mcp.sh"
# shellcheck source=lib/check_guidelines.sh
source "${TOOLBOX_DIR}/lib/check_guidelines.sh"
# shellcheck source=lib/context-lock.sh
source "${TOOLBOX_DIR}/lib/context-lock.sh"
# shellcheck source=lib/sync.sh
source "${TOOLBOX_DIR}/lib/sync.sh"

# ── Constants ───────────────────────────────────────────────────────────────────
GLOBAL_CONFIG_DIR="${HOME}/.config/counterpart"
GLOBAL_CONFIG="${GLOBAL_CONFIG_DIR}/config.json"
TOOLBOX_INSTALL_DIR="${HOME}/.local/share/counterpart-toolbox"
TOOLBOX_VERSION="$(cat "${TOOLBOX_DIR}/VERSION" 2>/dev/null | tr -d '[:space:]' || echo "unknown")"

# ── Colour helpers ──────────────────────────────────────────────────────────────
BOLD="\033[1m"
RESET="\033[0m"
CYAN="\033[36m"
YELLOW="\033[33m"

banner() {
  echo ""
  echo -e "${BOLD}${CYAN}  yourcounterpart — Counterpart AI toolbox${RESET}  ${YELLOW}v${TOOLBOX_VERSION}${RESET}"
  echo -e "  ${YELLOW}yourcounterpart.com${RESET}"
  echo ""
}

# ── Update check ─────────────────────────────────────────────────────────────────
# Instant: compares local VERSION against last-fetched remote state (no network call).
# Background fetch at end of each run keeps remote state fresh for the next invocation.

check_for_update() {
  [[ ! -d "${TOOLBOX_INSTALL_DIR}/.git" ]] && return 0
  local remote_version
  remote_version=$(git -C "$TOOLBOX_INSTALL_DIR" show origin/main:VERSION 2>/dev/null | tr -d '[:space:]' || echo "")
  if [[ -n "$remote_version" && "$remote_version" != "$TOOLBOX_VERSION" ]]; then
    echo -e "  ${YELLOW}↑${RESET} Update available: ${TOOLBOX_VERSION} → ${remote_version}  (run: ${BOLD}yourcounterpart update${RESET})"
    echo ""
  fi
}

# Triggers a non-blocking background fetch so the next run's check_for_update has fresh data.
trigger_background_fetch() {
  [[ ! -d "${TOOLBOX_INSTALL_DIR}/.git" ]] && return 0
  git -C "$TOOLBOX_INSTALL_DIR" fetch origin main --quiet 2>/dev/null &
}

# ── Workspace / config resolution ──────────────────────────────────────────────

load_workspace() {
  if [[ ! -f "$GLOBAL_CONFIG" ]]; then
    return 1
  fi
  local workspace
  workspace=$(jq -r '.workspace // empty' "$GLOBAL_CONFIG" 2>/dev/null)
  if [[ -z "$workspace" ]]; then
    return 1
  fi
  export COUNTERPART_WORKSPACE="$workspace"
  export COUNTERPART_CONFIG="${workspace}/.counterpart/config.json"
  return 0
}

# ── First-run setup wizard ──────────────────────────────────────────────────────

run_setup() {
  banner
  echo -e "${BOLD}First-time setup${RESET}"
  echo ""

  # 1. Ask for workspace path
  local default_workspace="${PWD}"
  printf "  Where is your Counterpart workspace folder? [%s] " "$default_workspace"
  read -r workspace </dev/tty
  workspace="${workspace:-$default_workspace}"
  # Expand ~
  workspace="${workspace/#\~/$HOME}"

  # 2. Validate path
  if [[ ! -d "$workspace" ]]; then
    echo ""
    echo "  Directory '$workspace' does not exist."
    printf "  Create it? [Y/n] "
    read -r answer </dev/tty
    answer="${answer:-Y}"
    if [[ "$answer" =~ ^[Yy]$ ]]; then
      mkdir -p "$workspace"
      echo "  Created: $workspace"
    else
      echo "  Setup aborted. Re-run with: yourcounterpart setup"
      exit 1
    fi
  fi

  # 3. Create .counterpart/ structure
  local cp_dir="${workspace}/.counterpart"
  mkdir -p "$cp_dir"

  # 4. Write default config.json if not present
  if [[ ! -f "${cp_dir}/config.json" ]]; then
    if [[ -f "${TOOLBOX_DIR}/templates/config.json" ]]; then
      cp "${TOOLBOX_DIR}/templates/config.json" "${cp_dir}/config.json"
    else
      cat > "${cp_dir}/config.json" <<'EOF'
{
  "version": "1.0.0",
  "marketplaces": [
    "git@github.com:counterpart-inc/counterpart-plugins.git",
    "anthropics/claude-plugins-official"
  ],
  "required_plugins": ["cmpd", "hire", "plugin-dev", "pyright-lsp"],
  "required_tools": [
    {"cmd": "jq",       "brew": "jq"},
    {"cmd": "rg",       "brew": "ripgrep"},
    {"cmd": "ast-grep", "brew": "ast-grep"}
  ],
  "mcp_servers": {
    "linear":   "https://mcp.linear.app/sse",
    "sentry":   "https://mcp.sentry.dev/mcp",
    "context7": "https://mcp.context7.com/mcp"
  },
  "guidelines_header": "# Counterpart Guidelines"
}
EOF
    fi
    echo "  [✓] Created ${cp_dir}/config.json"
  fi

  # 5. Copy guidelines template → .counterpart/guidelines.md
  if [[ ! -f "${cp_dir}/guidelines.md" ]]; then
    if [[ -f "${TOOLBOX_DIR}/templates/guidelines.md" ]]; then
      cp "${TOOLBOX_DIR}/templates/guidelines.md" "${cp_dir}/guidelines.md"
      echo "  [✓] Created ${cp_dir}/guidelines.md"
    fi
  fi

  # 6. Write state.json
  if [[ ! -f "${cp_dir}/state.json" ]]; then
    echo '{"last_check": null, "installed_versions": {}}' > "${cp_dir}/state.json"
    echo "  [✓] Created ${cp_dir}/state.json"
  fi

  # 7. Save global config
  mkdir -p "$GLOBAL_CONFIG_DIR"
  printf '{"workspace": "%s"}\n' "$workspace" > "$GLOBAL_CONFIG"
  echo "  [✓] Saved global config: $GLOBAL_CONFIG"

  # 8. Export for health check
  export COUNTERPART_WORKSPACE="$workspace"
  export COUNTERPART_CONFIG="${cp_dir}/config.json"

  echo ""
  echo -e "${BOLD}Running health checks...${RESET}"
  echo ""
  run_health_checks
  echo ""

  echo -e "${BOLD}Detecting AI agents...${RESET}"
  echo ""
  local detected_providers=()
  command -v claude &>/dev/null && detected_providers+=("claude") && echo "  [✓] Claude Code detected"
  [[ -d "${HOME}/.cursor" ]] && detected_providers+=("cursor") && echo "  [✓] Cursor detected"
  command -v opencode &>/dev/null && detected_providers+=("opencode") && echo "  [✓] OpenCode detected"
  [[ -d "${HOME}/.config/github-copilot" ]] && detected_providers+=("copilot") && echo "  [✓] Copilot detected"
  echo ""

  local plugins_dir="${HOME}/.local/share/counterpart-toolbox/plugins"
  local global_agents_dir="${HOME}/.agents"

  if [[ -d "$plugins_dir/.agents" ]]; then
    echo -e "${BOLD}Syncing company context...${RESET}"
    echo ""
    mkdir -p "$global_agents_dir/rules" "$global_agents_dir/skills"
    rsync -a --delete "${plugins_dir}/.agents/" "${global_agents_dir}/" 2>/dev/null || \
      cp -r "${plugins_dir}/.agents/." "${global_agents_dir}/"
    sync_global "$global_agents_dir"
    echo ""
  fi

  echo -e "${BOLD}Setup complete.${RESET} Open your AI agent — company context is already configured."
  echo ""
}

# ── Update flow ─────────────────────────────────────────────────────────────────

run_update() {
  banner
  echo -e "${BOLD}Updating counterpart-toolbox...${RESET}"
  echo ""

  if [[ ! -d "${TOOLBOX_INSTALL_DIR}/.git" ]]; then
    echo "  [!] Toolbox git repo not found at ${TOOLBOX_INSTALL_DIR}"
    echo "      If you installed manually, cd there and run: git pull"
    echo ""
  else
    local version_before="$TOOLBOX_VERSION"

    echo "  Pulling latest toolbox..."
    git -C "$TOOLBOX_INSTALL_DIR" pull origin main 2>&1 | sed 's/^/  /'
    echo ""

    echo "  Updating plugins submodule..."
    git -C "$TOOLBOX_INSTALL_DIR" submodule update --remote --merge 2>&1 | sed 's/^/  /'
    echo ""

    local version_after
    version_after=$(cat "${TOOLBOX_INSTALL_DIR}/VERSION" 2>/dev/null | tr -d '[:space:]' || echo "unknown")
    if [[ "$version_after" != "$version_before" ]]; then
      echo "  [✓] Toolbox updated: v${version_before} → v${version_after}"
    else
      echo "  [✓] Toolbox already at v${version_after} — no new version."
    fi
    echo ""
  fi

  local global_agents_dir="${HOME}/.agents"
  local plugins_dir="${HOME}/.local/share/counterpart-toolbox/plugins"

  if [[ -d "$plugins_dir/.agents" ]]; then
    echo "  Syncing company context to agents..."
    mkdir -p "$global_agents_dir"
    rsync -a --delete "${plugins_dir}/.agents/" "${global_agents_dir}/" 2>/dev/null || \
      cp -r "${plugins_dir}/.agents/." "${global_agents_dir}/"
    sync_global "$global_agents_dir"
    if [[ -d "$PWD/.agents" ]]; then
      sync_local "$PWD" "$PWD/.agents"
    fi
    echo ""
  fi

  echo -e "${BOLD}Update complete.${RESET}"
  echo ""
}

# ── Reset flow ──────────────────────────────────────────────────────────────────

run_reset() {
  banner
  echo -e "${BOLD}Reset yourcounterpart configuration${RESET}"
  echo ""
  echo "  This will delete:"
  echo "    • ${GLOBAL_CONFIG}  (global config)"

  if load_workspace 2>/dev/null; then
    echo "    • ${COUNTERPART_WORKSPACE}/.counterpart/  (workspace state)"
  fi

  echo ""
  printf "  Are you sure? [y/N] "
  read -r answer </dev/tty
  answer="${answer:-N}"
  if [[ ! "$answer" =~ ^[Yy]$ ]]; then
    echo "  Aborted."
    exit 0
  fi

  rm -f "$GLOBAL_CONFIG"
  echo "  [✓] Removed global config."

  if [[ -n "${COUNTERPART_WORKSPACE:-}" && -d "${COUNTERPART_WORKSPACE}/.counterpart" ]]; then
    rm -rf "${COUNTERPART_WORKSPACE}/.counterpart"
    echo "  [✓] Removed ${COUNTERPART_WORKSPACE}/.counterpart/"
  fi

  echo ""
  echo -e "${BOLD}Reset complete.${RESET} Run 'yourcounterpart setup' to reconfigure."
  echo ""
}

# ── Uninstall flow ───────────────────────────────────────────────────────────────

run_uninstall() {
  banner
  echo -e "${BOLD}Uninstall yourcounterpart${RESET}"
  echo ""
  echo "  This will delete:"
  echo "    • ${HOME}/.local/bin/yourcounterpart  (symlink)"
  echo "    • ${TOOLBOX_INSTALL_DIR}/  (toolbox repo)"
  echo "    • ${GLOBAL_CONFIG_DIR}/  (global config)"
  echo "    • Required Claude plugins and marketplaces"

  if load_workspace 2>/dev/null; then
    echo ""
    printf "  Also remove workspace config (%s/.counterpart/)? [y/N] " "$COUNTERPART_WORKSPACE"
    read -r remove_workspace </dev/tty
    remove_workspace="${remove_workspace:-N}"
  fi

  echo ""
  printf "  Are you sure you want to uninstall? [y/N] "
  read -r answer </dev/tty
  answer="${answer:-N}"
  if [[ ! "$answer" =~ ^[Yy]$ ]]; then
    echo "  Aborted."
    exit 0
  fi

  rm -f "${HOME}/.local/bin/yourcounterpart"
  echo "  [✓] Removed symlink."

  # Remove completion lines from rc files
  for rc_file in "${HOME}/.zshrc" "${HOME}/.bashrc" "${HOME}/.bash_profile"; do
    if [[ -f "$rc_file" ]] && grep -qF 'yourcounterpart' "$rc_file"; then
      # Remove the comment line and the source line added by the installer
      local tmp
      tmp=$(mktemp)
      grep -v 'yourcounterpart' "$rc_file" | grep -v 'counterpart-toolbox installer' > "$tmp"
      mv "$tmp" "$rc_file"
      echo "  [✓] Removed completions from ${rc_file}."
    fi
  done

  if [[ -d "$TOOLBOX_INSTALL_DIR" ]]; then
    rm -rf "$TOOLBOX_INSTALL_DIR"
    echo "  [✓] Removed ${TOOLBOX_INSTALL_DIR}/"
  fi

  rm -rf "$GLOBAL_CONFIG_DIR"
  echo "  [✓] Removed ${GLOBAL_CONFIG_DIR}/"

  if [[ -d "${HOME}/.claude/plugins/cache" ]]; then
    rm -rf "${HOME}/.claude/plugins/cache"
    echo "  [✓] Cleared Claude plugin cache."
  fi

  if [[ "${remove_workspace:-N}" =~ ^[Yy]$ && -n "${COUNTERPART_WORKSPACE:-}" ]]; then
    rm -rf "${COUNTERPART_WORKSPACE}/.counterpart"
    echo "  [✓] Removed ${COUNTERPART_WORKSPACE}/.counterpart/"
  fi

  echo ""
  echo -e "${BOLD}Uninstalled.${RESET} To reinstall, follow the onboarding instructions."
  echo ""
}

# ── Health check runner ─────────────────────────────────────────────────────────

run_health_checks() {
  local all_ok=0

  # [1] required CLI tools (jq, ripgrep, etc.)
  check_tools

  # [2] MCP servers
  check_mcp_servers || { all_ok=1; return 1; }

  # [3] guidelines
  check_guidelines

  # Update last_check timestamp in state.json
  local state_file="${COUNTERPART_WORKSPACE}/.counterpart/state.json"
  if [[ -f "$state_file" ]] && command -v jq &>/dev/null; then
    local tmp
    tmp=$(mktemp)
    jq --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" '.last_check = $ts' "$state_file" > "$tmp" && mv "$tmp" "$state_file"
  fi

  return "$all_ok"
}

# ── Status subcommand ───────────────────────────────────────────────────────────

run_status() {
  banner
  echo -e "${BOLD}Health check${RESET}"
  echo ""

  if ! load_workspace; then
    echo "  [!] Not configured. Run: yourcounterpart setup"
    echo ""
    exit 1
  fi

  check_for_update
  run_health_checks
  echo ""

  local state_file="${COUNTERPART_WORKSPACE}/.counterpart/state.json"
  if [[ -f "$state_file" ]]; then
    local last_check
    last_check=$(jq -r '.last_check // "never"' "$state_file" 2>/dev/null)
    echo "  Version:    v${TOOLBOX_VERSION}"
    echo "  Last check: $last_check"
    echo ""
  fi
}

# ── Main entry point ────────────────────────────────────────────────────────────

main() {
  # Handle subcommands that don't need a workspace check first
  case "${1:-}" in
    setup)
      run_setup
      exit 0
      ;;
    update)
      run_update
      exit 0
      ;;
    context)
      local subcmd="${2:-}"
      case "$subcmd" in
        sync)
          context_lock_generate "context" "context.lock" "$PWD"
          exit $?
          ;;
        validate)
          context_lock_validate "context" "context.lock" "$PWD"
          exit $?
          ;;
        *)
          echo "  Usage: yourcounterpart context <sync|validate>"
          exit 1
          ;;
      esac
      ;;
    status)
      run_status
      exit 0
      ;;
    reset)
      run_reset
      exit 0
      ;;
    uninstall)
      run_uninstall
      exit 0
      ;;
    --help|-h|help)
      banner
      cat <<'USAGE'
  Usage:
    yourcounterpart            Check environment status
    yourcounterpart setup      Detect agents, install company context
    yourcounterpart update     Pull latest plugins and re-sync
    yourcounterpart status     Show health check results
    yourcounterpart reset      Clear configuration and start fresh
    yourcounterpart uninstall  Remove yourcounterpart from this machine

USAGE
      exit 0
      ;;
  esac

  # Normal invocation: health check and show status
  if ! load_workspace; then
    banner
    echo "  No configuration found. Running first-time setup..."
    echo ""
    run_setup
    echo ""
  else
    # Quiet health checks on each invocation
    echo ""
    echo -e "${BOLD}${CYAN}yourcounterpart${RESET}  v${TOOLBOX_VERSION}  checking environment..."
    echo ""

    check_for_update

    if ! run_health_checks; then
      echo ""
      echo "  Some checks failed. Run 'yourcounterpart status' for details."
      exit 1
    fi
    echo ""
  fi

  trigger_background_fetch
  echo "  Environment ready. Open your AI agent — company context is already configured."
  echo ""
}

main "$@"
