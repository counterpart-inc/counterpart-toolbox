{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Counterpart Plugin Manifest",
  "description": "Schema for counterpart-plugins manifest. Describes what a plugin package contains.",
  "type": "object",
  "required": ["name", "version", "description"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Unique plugin identifier (kebab-case)",
      "pattern": "^[a-z][a-z0-9-]*$",
      "examples": ["counterpart-core", "underwriting-tools"]
    },
    "version": {
      "type": "string",
      "description": "Semantic version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["1.0.0", "0.3.2"]
    },
    "description": {
      "type": "string",
      "description": "One-sentence description of what this plugin provides"
    },
    "agents": {
      "type": "array",
      "description": "Agent definition files under .agents/agents/",
      "items": { "type": "string" },
      "examples": [["default.md", "reviewer.md"]]
    },
    "rules": {
      "type": "array",
      "description": "Rule files under .agents/rules/",
      "items": { "type": "string" },
      "examples": [["code-quality.md", "security.md"]]
    },
    "skills": {
      "type": "array",
      "description": "Skill directories under .agents/skills/",
      "items": { "type": "string" },
      "examples": [["capture", "doc-check", "pr-create"]]
    },
    "mcp": {
      "type": "boolean",
      "description": "Whether this plugin includes .agents/mcp.json",
      "default": false
    },
    "providers": {
      "type": "array",
      "description": "AI agent providers this plugin explicitly supports",
      "items": {
        "type": "string",
        "enum": ["claude", "cursor", "copilot", "opencode", "gemini", "pi", "codex"]
      },
      "examples": [["claude", "cursor", "opencode"]]
    },
    "minToolboxVersion": {
      "type": "string",
      "description": "Minimum counterpart-toolbox version required",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["2.0.0"]
    }
  },
  "additionalProperties": false
}
