#!/usr/bin/env bash
# counterpart — Counterpart AI toolbox
#
# Usage:
#   counterpart sync       Sync AI context to all configured providers
#   counterpart status     Show sync status
#   counterpart configure  Re-run the interactive provider/asset setup
#   counterpart update     Pull latest toolbox + re-sync

set -euo pipefail

# ── Resolve toolbox root ────────────────────────────────────────────────────────
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SOURCE" ]]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
export TOOLBOX_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"

# ── Load libs ───────────────────────────────────────────────────────────────────
source "${TOOLBOX_DIR}/lib/providers.sh"
source "${TOOLBOX_DIR}/lib/section-merger.sh"
source "${TOOLBOX_DIR}/lib/json-merger.sh"
source "${TOOLBOX_DIR}/lib/plugins-source.sh"
source "${TOOLBOX_DIR}/lib/lock.sh"
source "${TOOLBOX_DIR}/lib/update-check.sh"
source "${TOOLBOX_DIR}/lib/sync/claude.sh"
source "${TOOLBOX_DIR}/lib/sync/opencode.sh"
source "${TOOLBOX_DIR}/lib/sync/pi.sh"
source "${TOOLBOX_DIR}/lib/sync/cursor.sh"

# ── Constants ───────────────────────────────────────────────────────────────────
VERSION="$(cat "${TOOLBOX_DIR}/VERSION" 2>/dev/null | tr -d '[:space:]' || echo "?")"
PREFS_FILE="${HOME}/.config/counterpart/sync.json"
BOLD="\033[1m"; RESET="\033[0m"; CYAN="\033[36m"; YELLOW="\033[33m"; DIM="\033[2m"; GREEN="\033[32m"

# ── UI helpers ──────────────────────────────────────────────────────────────────

banner() {
  echo ""
  echo -e "${BOLD}${CYAN}  counterpart${RESET}  ${YELLOW}v${VERSION}${RESET}"
  echo ""
}

_ask_yn() {
  local prompt="$1" default="${2:-y}"
  local hint="[Y/n]"; [[ "$default" == "n" ]] && hint="[y/N]"
  printf "    %s %s " "$prompt" "$hint"
  local answer; read -r answer </dev/tty
  answer="${answer:-$default}"
  answer=$(echo "$answer" | tr '[:upper:]' '[:lower:]')
  [[ "$answer" =~ ^y ]]
}

# ── Prefs ───────────────────────────────────────────────────────────────────────

_prefs_load() {
  if [[ ! -f "$PREFS_FILE" ]]; then return 1; fi
  command -v jq &>/dev/null || return 1
}

_prefs_get_assets() {
  local provider="$1"
  jq -r --arg p "$provider" '.providers[$p][]?' "$PREFS_FILE" 2>/dev/null
}

_prefs_get_providers() {
  jq -r '.providers | keys[]' "$PREFS_FILE" 2>/dev/null
}

# _prefs_write <json_string>
_prefs_write() {
  mkdir -p "$(dirname "$PREFS_FILE")"
  echo "$1" | jq . > "$PREFS_FILE"
}

# ── Interactive configure ────────────────────────────────────────────────────────

run_configure() {
  banner
  echo -e "${BOLD}Configure providers${RESET}"
  echo ""

  local detected=()
  while IFS= read -r p; do detected+=("$p"); done < <(detect_providers)

  if [[ ${#detected[@]} -eq 0 ]]; then
    echo "  No AI providers detected on this machine."
    echo "  Install Claude Code, OpenCode, Pi, or Cursor and run again."
    echo ""
    return 1
  fi

  echo "  Detected providers:"
  for p in "${detected[@]}"; do
    echo -e "    ${GREEN}✓${RESET} $(provider_label "$p")"
  done
  echo ""

  # For each detected provider, ask asset toggles
  local prefs_json='{"providers":{}}'

  for provider in "${detected[@]}"; do
    echo -e "  ${BOLD}$(provider_label "$provider")${RESET}"
    echo ""

    # Provider-level toggle
    if ! _ask_yn "Sync to $(provider_label "$provider")?" "y"; then
      echo ""
      continue
    fi
    echo ""

    local selected_assets=()

    for asset in "${ALL_ASSETS[@]}"; do
      if provider_supports "$provider" "$asset"; then
        local desc
        desc=$(asset_description "$provider" "$asset")
        echo -e "    ${BOLD}${asset}${RESET}"
        echo -e "    ${DIM}${desc}${RESET}"
        if _ask_yn "Include?" "y"; then
          selected_assets+=("$asset")
        fi
      else
        echo -e "    ${DIM}${asset} — not supported by $(provider_label "$provider")${RESET}"
      fi
      echo ""
    done

    if [[ ${#selected_assets[@]} -gt 0 ]]; then
      local assets_json
      assets_json=$(printf '%s\n' "${selected_assets[@]}" | jq -Rsc 'split("\n") | map(select(length>0))')
      prefs_json=$(echo "$prefs_json" | jq --arg p "$provider" --argjson a "$assets_json" \
        '.providers[$p] = $a')
    fi
  done

  _prefs_write "$prefs_json"
  echo -e "  ${GREEN}[✓]${RESET} Preferences saved to ${PREFS_FILE}"
  echo ""
}

# ── Sync ────────────────────────────────────────────────────────────────────────

run_sync() {
  # Parse flags
  local local_source=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --source) local_source="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  banner

  # First run — configure if no prefs
  if ! _prefs_load; then
    echo -e "  First time? Let's set up your providers."
    echo ""
    run_configure
    echo ""
  fi

  echo -e "${BOLD}  Syncing AI context...${RESET}"
  echo ""

  local cache_dir old_lock new_lock

  if [[ -n "$local_source" ]]; then
    # Local mode — skip fetch, use provided directory directly
    if [[ ! -d "$local_source" ]]; then
      echo "  [✗] --source directory not found: $local_source" >&2
      exit 1
    fi
    cache_dir="$local_source"
    echo -e "  ${DIM}[local] using source: ${local_source}${RESET}"
    echo ""
  else
    # Remote mode — fetch counterpart-plugins@generated
    fetch_plugins_source
    echo ""
    cache_dir=$(plugins_source_dir)
  fi

  old_lock="$PLUGINS_LOCK"
  new_lock="${cache_dir}/counterpart-ai.lock"

  if [[ ! -f "$new_lock" ]]; then
    echo "  [✗] counterpart-ai.lock not found in source — is this a valid generated directory?" >&2
    exit 1
  fi

  # Show hash transition — skip if identical
  local old_agg new_agg
  old_agg=$(lock_aggregate "$old_lock" 2>/dev/null || echo "")
  new_agg=$(lock_aggregate "$new_lock")

  if [[ -n "$old_agg" && "$old_agg" == "$new_agg" ]]; then
    echo "  Already up to date."
    echo ""
    return 0
  fi

  echo -e "  ${DIM}${old_agg:0:12} → ${new_agg:0:12}${RESET}"
  echo ""

  # Prune stale files before copying new ones
  if [[ -f "$old_lock" ]]; then
    echo "  Pruning stale files..."
    lock_prune_stale "$old_lock" "$new_lock" \
      "claude:${HOME}/.claude" \
      "opencode:${HOME}/.config/opencode" \
      "pi:${HOME}/.pi/agent" \
      "cursor:${HOME}/.cursor"
    echo ""
  fi

  # Sync each configured provider
  while IFS= read -r provider; do
    local assets=()
    while IFS= read -r asset; do
      assets+=("$asset")
    done < <(_prefs_get_assets "$provider")

    if [[ ${#assets[@]} -eq 0 ]]; then continue; fi

    echo -e "  ${BOLD}$(provider_label "$provider")${RESET}"

    local source_dir="${cache_dir}/${provider}"
    # Pi source dir is the cache root (not cache/pi)
    if [[ "$provider" == "pi" ]]; then source_dir="${cache_dir}"; fi

    "sync_provider_${provider}" "$source_dir" "${assets[@]}"
    echo ""
  done < <(_prefs_get_providers)

  # Update local lock
  lock_update "$new_lock"

  echo -e "${BOLD}  Sync complete.${RESET}"
  echo ""
}

# ── Status ───────────────────────────────────────────────────────────────────────

run_status() {
  banner
  echo -e "${BOLD}  Status${RESET}"
  echo ""

  echo "  Version:   v${VERSION}"

  if [[ -f "$PREFS_FILE" ]]; then
    echo "  Config:    ${PREFS_FILE}"
    if command -v jq &>/dev/null; then
      local providers
      providers=$(jq -r '.providers | keys | join(", ")' "$PREFS_FILE" 2>/dev/null || echo "(none)")
      echo "  Providers: ${providers}"
    fi
  else
    echo "  Config:    not configured — run: counterpart sync"
  fi

  if [[ -f "$PLUGINS_LOCK" ]]; then
    local agg; agg=$(lock_aggregate "$PLUGINS_LOCK")
    echo "  Lock:      ${agg:0:12}..."
  else
    echo "  Lock:      not synced yet"
  fi

  echo ""
}

# ── Update ───────────────────────────────────────────────────────────────────────

run_update() {
  banner
  echo -e "${BOLD}  Updating counterpart-toolbox...${RESET}"
  echo ""

  local install_dir="${HOME}/.local/share/counterpart-toolbox"
  if [[ -d "${install_dir}/.git" ]]; then
    git -C "$install_dir" pull origin main 2>&1 | sed 's/^/  /'
    echo ""
    echo -e "  ${GREEN}[✓]${RESET} Toolbox updated"
    echo ""
  fi

  run_sync
}

run_uninstall() {
  local yes=0
  [[ "${1:-}" == "--yes" ]] && yes=1

  banner

  if [[ $yes -eq 0 ]]; then
    echo -e "  This will remove:"
    echo -e "    ~/.local/bin/counterpart"
    echo -e "    ~/.local/share/counterpart-toolbox"
    echo -e "    ~/.config/counterpart"
    echo -e "    Shell hook from ~/.zshrc and ~/.bashrc"
    echo ""
    if ! _ask_yn "Continue?"; then
      echo "  Aborted."
      return 0
    fi
    echo ""
  fi

  rm -f "${HOME}/.local/bin/counterpart"
  echo -e "  ${GREEN}[✓]${RESET} Removed ~/.local/bin/counterpart"

  rm -rf "${HOME}/.local/share/counterpart-toolbox"
  echo -e "  ${GREEN}[✓]${RESET} Removed ~/.local/share/counterpart-toolbox"

  rm -rf "${HOME}/.config/counterpart"
  echo -e "  ${GREEN}[✓]${RESET} Removed ~/.config/counterpart"

  local removed_hook=0
  for rc in "${HOME}/.zshrc" "${HOME}/.bashrc"; do
    if grep -qF "# >>> counterpart-toolbox" "$rc" 2>/dev/null; then
      local tmp; tmp=$(mktemp)
      awk "/# >>> counterpart-toolbox/{skip=1} /# <<< counterpart-toolbox/{skip=0; next} !skip{print}" "$rc" > "$tmp"
      mv "$tmp" "$rc"
      echo -e "  ${GREEN}[✓]${RESET} Removed hook from ${rc}"
      removed_hook=1
    fi
  done
  [[ $removed_hook -eq 0 ]] && echo -e "  ${DIM}[–]${RESET} No shell hook found"

  echo ""
  echo -e "  ${BOLD}Done.${RESET} Open a new terminal to complete uninstall."
  echo ""
}

# ── Main ────────────────────────────────────────────────────────────────────────

main() {
  case "${1:-}" in
    sync)       run_sync "${@:2}" ;;
    configure)  run_configure ;;
    status)     run_status ;;
    update)     run_update ;;
    uninstall)  run_uninstall "${@:2}" ;;
    --help|-h|help|"")
      banner
      cat <<'USAGE'
  Usage:
    counterpart sync                        Sync AI context to all configured providers
    counterpart sync --source <dir>         Sync from a local generated/ directory (dev/test)
    counterpart configure                   Re-run interactive provider/asset setup
    counterpart status                      Show sync status and configuration
    counterpart update                      Pull latest toolbox + re-sync
    counterpart uninstall                   Remove counterpart-toolbox from this machine

USAGE
      ;;
    *)
      echo "Unknown command: ${1}" >&2
      echo "Run 'counterpart --help' for usage." >&2
      exit 1
      ;;
  esac
}

main "$@"
