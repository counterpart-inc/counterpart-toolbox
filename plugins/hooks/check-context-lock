#!/usr/bin/env bash
[[ "${SKIP_CONTEXT_CHECK:-0}" == "1" ]] && exit 0

TOOLBOX_DIR="${COUNTERPART_TOOLBOX_DIR:-${HOME}/.local/share/counterpart-toolbox}"
[[ ! -f "${TOOLBOX_DIR}/lib/context-lock.sh" ]] && exit 0

source "${TOOLBOX_DIR}/lib/context-lock.sh"

if git diff --cached --name-only | grep -q "^context/"; then
  if ! context_lock_validate "context" "context.lock" "$PWD" 2>/dev/null; then
    echo ""
    echo "  [!] context/ files changed but context.lock is stale"
    echo "      Run: yourcounterpart context sync"
    echo "      Then: git add context.lock"
    echo "      Or skip: SKIP_CONTEXT_CHECK=1 git commit"
    echo ""
  fi
fi
exit 0
